---
- name: Installation of PowerDNS & tools. Configuration of a domain name
  hosts: serv3
  become: true
  vars:
    domain: my.cloud
    subdomain: example

  tasks:
    - name: Install PowerDNS
      include_role:
        name: install_package
      vars:
        apt_name: pdns-server
# - hosts: all
#   roles:
#    - { role: PowerDNS.pdns,
#        pdns_install_repo: "{{ pdns_auth_powerdns_repo_master }}"
#
    - name: Install PowerDNS tools
      include_role:
        name: install_package
      vars:
        apt_name: pdns-tools

    - name: Configure PowerDNS
      include_role:
        name: generate_domain_name # Add my.cloud
      vars:
        zone: "my.cloud"
        type: "A"
        value:
        ttl:
    - name: Configure SubDomain # Add example.my.cloud
      include_role:
        name: sub_domain_generation
      vars:
        zone: {{ subdomain }}
...
