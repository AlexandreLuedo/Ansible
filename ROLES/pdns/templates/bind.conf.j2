{# Bind conf file will be read by PowerDNS, this file indicate where is the zone file #}
# ----------------------------------------------
# File generated by Ansible – {{ ansible_date_time.iso8601 }}
# ---------------------------------------------

{% for domain in domains %}
zone "{{ domain }}.cloud" {
    type master;
    file "{{ pdns_path }}/{{ domain }}.zone";
};

{% endfor %}
